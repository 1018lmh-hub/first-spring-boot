<!DOCTYPE html>
<html>
	<head>
		<meta charset="UTF-8"/>
		<title>공지사항이당</title>
	</head>
	<body>
		
		<div id="outer" style="width:1200px; height: 450px; margin:auto; border: 1px solid lightgrey;">
			
			
		</div>
		
		<script>
			
			function getNotices(){
				
				fetch('http://localhost/api/notices')
				.then(res => res.json())
				.then(data=>{
					console.log(data);
					const el = data.map(e =>`
												<div>
													<h3>${e.noticeTitle}</h3>
													<p>
														${e.noticeContent}
													</p>
													<label>게시글번호 : ${e.noticeNo}</label> / <label>작성자 : ${e.noticeWriter}</label>
												</div>
											`).join('');
				document.querySelector('#outer').innerHTML = el;
				});
			};
			
			window.onload = () => {
				getNotices();
				
			}
		
		</script>
		
	</body>
</html>
